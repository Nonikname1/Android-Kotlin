<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow HTTP for all private/local addresses (dev only) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">10.0.2.2</domain>       <!-- эмулятор -->
        <domain includeSubdomains="true">127.0.0.1</domain>
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">192.168.0.1</domain>    <!-- роутер/сеть -->
        <domain includeSubdomains="true">192.168.1.1</domain>
    </domain-config>
    <!-- Любой IP 192.168.x.x — добавить свой если отличается -->
    <base-config cleartextTrafficPermitted="true" />
</network-security-config>
